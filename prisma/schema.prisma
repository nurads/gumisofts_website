// Gumisofts Prisma schema - SQLite for dev (switch DATABASE_URL for Postgres in prod)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ---- Auth (admin users) ----

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String?
  password      String // bcrypt hash
  role          String   @default("admin") // admin | editor | viewer
  emailVerified DateTime?
  image         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  accounts Account[]
  sessions Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ---- Company ----

model CompanyInfo {
  id                          String  @id @default(cuid())
  companyName                 String
  email                       String
  phone                       String
  address                     String
  yearsOfExprience            Int     @default(0)
  clientSatisficationRate     Int     @default(95)
  numberOfProjectsCompleted   Int     @default(0)
  numberOfHappyClients        Int     @default(0)
  numberOfYearsInBusiness     Int     @default(0)
  numberOfEmployees           Int     @default(0)
  numberOfServices            Int     @default(0)
  scheduleUrl                 String  @default("")
  linkedinUrl                 String  @default("")
  githubUrl                   String  @default("")
  telegramUrl                 String  @default("")
  facebookUrl                 String  @default("")
  instagramUrl                String  @default("")
  whatsappUrl                 String  @default("")
  youtubeUrl                  String  @default("")
  isDefault                   Boolean @default(false)
  companyLocation             String  @default("")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ---- Services ----

model Service {
  id               String   @id @default(cuid())
  title            String
  description      String
  shortDescription String
  icon             String   @default("FiCloud")
  category         String   @default("Development")
  features         String   @default("[]") // JSON array of strings
  pricingBasic     Int?
  pricingPremium   Int?
  pricingEnterprise Int?
  order            Int      @default(0)
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

// ---- Products ----

model Product {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  tagline     String
  description String
  icon        String   @default("FiBox")
  features    String   @default("[]") // JSON array of strings
  benefits    String   @default("[]") // JSON array of strings
  demoUrl     String   @default("")
  isActive    Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  pricingTiers ProductPricingTier[]
}

model ProductPricingTier {
  id        String  @id @default(cuid())
  productId String
  name      String  // starter | professional | enterprise
  price     String  // e.g. "0 ETB", "$10"
  users     String  // e.g. "5", "Unlimited"
  features  String  // text description
  order     Int     @default(0)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

// ---- Projects (portfolio "Work") ----

model Project {
  id           String   @id @default(cuid())
  title        String
  description  String
  image        String
  category     String   @default("Web Development")
  technologies String   @default("[]") // JSON array of strings
  demoUrl      String?
  githubUrl    String?
  isFeatured   Boolean  @default(true)
  order        Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ---- Testimonials ----

model Testimonial {
  id         String   @id @default(cuid())
  name       String
  position   String
  company    String   @default("")
  avatar     String   @default("")
  comment    String
  rating     Int      @default(5)
  isApproved Boolean  @default(true)
  order      Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ---- Jobs ----

model Job {
  id              String   @id @default(cuid())
  title           String
  department      String
  location        String
  type            String   @default("full-time") // full-time | part-time | contract | internship
  experience      String
  description     String
  requirements    String   @default("[]") // JSON array of strings
  responsibilities String   @default("[]") // JSON array of strings
  benefits        String   @default("[]") // JSON array of strings
  salaryMin       Int?
  salaryMax       Int?
  salaryCurrency  String?  @default("USD")
  postedAt        DateTime @default(now())
  deadline        DateTime
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  applications JobApplication[]
}

model JobApplication {
  id          String   @id @default(cuid())
  jobId       String
  fullName    String
  email       String
  linkedIn    String   @default("")
  resumeUrl   String   @default("") // path or URL where resume is stored
  coverLetter String?
  status      String   @default("pending") // pending | reviewed | interview | hired | rejected
  appliedAt   DateTime @default(now())
  notes       String? // internal CRM notes

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)
}

// ---- Blog ----

model BlogPost {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  excerpt     String
  content     String
  authorName  String
  authorBio   String   @default("")
  authorAvatar String  @default("")
  publishedAt DateTime @default(now())
  tags        String   @default("[]") // JSON array of strings
  category    String
  image       String   @default("")
  readTime    Int      @default(5)
  featured    Boolean  @default(false)
  likes       Int      @default(0)
  views       Int      @default(0)
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ---- CRM: Leads / contact form messages ----

model Lead {
  id        String   @id @default(cuid())
  fullName  String
  email     String
  phone     String?
  company   String?
  content   String
  source    String   @default("contact-form") // contact-form | newsletter | manual
  status    String   @default("new") // new | contacted | qualified | won | lost | archived
  notes     String?  // internal CRM notes
  assignedToId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ---- Newsletter subscribers ----

model NewsletterSubscriber {
  id           String   @id @default(cuid())
  email        String   @unique
  isActive     Boolean  @default(true)
  subscribedAt DateTime @default(now())
  unsubscribedAt DateTime?
}

// ---- FAQ ----

model FAQ {
  id        String   @id @default(cuid())
  question  String
  answer    String
  category  String   @default("General")
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
